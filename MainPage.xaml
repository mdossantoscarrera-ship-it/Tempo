<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppTempoAgora.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30,20" Spacing="15">

            <!-- BOTÃO LOCALIZAÇÃO -->
            <Button Text="Minha Localização"
                    Clicked="Button_Clicked_Localizacao" />

            <Label x:Name="lbl_coords"
                   Text="Sua localização aparecerá aqui" />

            <!-- CAMPO CIDADE -->
            <Entry x:Name="txt_cidade"
                   Placeholder="Digite a cidade" />

            <!-- BOTÃO PREVISÃO -->
            <Button Text="Buscar Previsão"
                    Clicked="Button_Clicked_Previsao" />

            <!-- RESULTADO -->
            <Label x:Name="lbl_res" />

            <!-- MAPA -->
            <WebView x:Name="wv_mapa"
                     HeightRequest="500" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>